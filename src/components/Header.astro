---
import { withBase } from '../lib/urls';
import SubscribeButtons from './SubscribeButtons.astro';

const nav = [
	{ href: withBase('/'), label: 'בית' },
	{ href: withBase('/archive.html'), label: 'ארכיון' },
	{ href: withBase('/episodes.html'), label: 'פרקים' },
	{ href: withBase('/about.html'), label: 'אודות' },
];
---

<header class="site-header">
	<a class="skip-link" href="#content">דילוג לתוכן</a>
	<div class="brand">
		<a href={withBase('/')} class="brand-title">רברס עם פלטפורמה</a>
		<p class="brand-subtitle">פודקאסט על תוכנה, מוצר, ותשתיות — בעברית.</p>
	</div>
	<nav class="nav" aria-label="ניווט">
		{nav.map((item) => (
			<a class="nav-link" href={item.href}>
				{item.label}
			</a>
		))}
	</nav>
	<div id="search" class="search-container"></div>
	<link href={withBase('/pagefind/pagefind-ui.css')} rel="stylesheet" />
	<script is:inline define:vars={{ base: withBase('/') }}>
		window.addEventListener('DOMContentLoaded', () => {
			new PagefindUI({
				element: '#search',
				showSubResults: true,
				bundlePath: base + 'pagefind/',
				translations: {
					placeholder: 'חיפוש...',
					zero_results: 'לא נמצאו תוצאות עבור [SEARCH_TERM]',
				},
			});
		});
	</script>
	<script src={withBase('/pagefind/pagefind-ui.js')} is:inline />
	<SubscribeButtons />
</header>
